# ==============================================================================
# Slack Community Agent - Environment Configuration
# ==============================================================================
# Copy this to .env and fill in your values.
# Company/product identity is configured in config/agent.yaml (not here).

# ------------------------------------------------------------------------------
# Identity overrides (optional — defaults come from config/agent.yaml)
# ------------------------------------------------------------------------------
# AGENT_NAME=Alex
# COMPANY_NAME=OLake

# ------------------------------------------------------------------------------
# LLM Provider (choose one: openai | gemini | openrouter | ollama)
# ------------------------------------------------------------------------------
LLM_PROVIDER=openrouter

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (https://openrouter.ai/models)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local; no API key required — run: ollama serve && ollama pull <model>)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------------------------
# Slack API Credentials  (https://api.slack.com/apps)
# ------------------------------------------------------------------------------
# Required Bot Token Scopes: chat:write, reactions:write, users:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_ID=...
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# SQLite (default)
DATABASE_PATH=data/slack_agent.db

# PostgreSQL — set this to use the Docker Compose postgres service instead.
# From host (docker-compose maps host 5433 → container 5432):
# DATABASE_URL=postgresql://slack_agent:slack_agent_dev@localhost:5433/slack_agent
# From another container on the same compose network:
# DATABASE_URL=postgresql://slack_agent:slack_agent_dev@postgres:5432/slack_agent
DATABASE_URL=

# PostgreSQL password used by docker-compose (matches the DATABASE_URL above)
POSTGRES_PASSWORD=slack_agent_dev

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
WEBHOOK_PORT=8001
WEBHOOK_PATH=/slack/events

# Eval dashboard port (docker-compose --profile eval)
EVAL_APP_PORT=8000

# For local dev, expose via ngrok:
#   ngrok http 8001
# Then set Slack Request URL to: https://<ngrok-id>.ngrok.io/slack/events

# ------------------------------------------------------------------------------
# Channel configuration (optional)
# ------------------------------------------------------------------------------
IGNORED_CHANNELS=
HIGH_PRIORITY_CHANNELS=

# ------------------------------------------------------------------------------
# Advanced tuning (optional)
# ------------------------------------------------------------------------------
LLM_REQUEST_TIMEOUT_SECONDS=90
MAX_RESEARCH_ITERATIONS=20
MAX_CONTEXT_FILES=15
RESEARCH_TIMEOUT_SECONDS=120
